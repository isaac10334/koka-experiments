{
  "name": "Koka",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "postCreateCommand": "curl -sSL https://github.com/koka-lang/koka/releases/latest/download/install.sh | sh && echo 'export PATH=\"$HOME/.koka/bin:$PATH\"' >> ~/.bashrc",
  "customizations": {
    "vscode": {
      "extensions": ["koka.language-koka"]
    }
  }
}
